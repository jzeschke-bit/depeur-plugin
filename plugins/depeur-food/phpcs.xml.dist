<?xml version="1.0"?>
<ruleset name="Depeur Food">
	<description>WordPress Coding Standards für Depeur Food</description>

	<file>.</file>

	<!-- Nur PHP prüfen: JS/CSS folgen eigenen Konventionen (Vanilla-Assets), nicht WPCS. -->
	<arg name="extensions" value="php"/>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<!--
	Modul content-types ist geparkt (Default-OFF, ACF besitzt die CPTs). config/seed.php ist ein
	args-treuer Live-Dump (Daten, kein Handcode) → wird bis zur Reaktivierung vom Ruleset ausgenommen.
	-->
	<exclude-pattern>*/modules/content-types/*</exclude-pattern>

	<!--
	Das gebündelte Child-Theme (bundled-theme/) folgt bewusst KADENCE-Konventionen, nicht den
	Plugin-Konventionen: es überschreibt Kadence-Template-Parts und MUSS dafür `namespace Kadence`,
	die exakten Kadence-Dateinamen (entry_author.php …) und Kadence-Hook-Namen (kadence_*) nutzen.
	Diese „Verstöße" gegen PrefixAllGlobals/ValidHookName/FileName sind funktional zwingend →
	das Theme wird vom Plugin-Ruleset ausgenommen.
	-->
	<exclude-pattern>*/bundled-theme/*</exclude-pattern>

	<rule ref="WordPress-Core">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!--
	PSR-4-Klassendateien nutzen PascalCase-Pfade (Depeur\Food\Core\Plugin -> src/Core/Plugin.php).
	Das WPCS-FileName-Sniff erwartet lowercase-hyphenated und kollidiert mit PSR-4, daher für die
	Autoload-Verzeichnisse abgeschaltet. Root-/Funktionsdateien (depeur-food.php, uninstall.php)
	bleiben weiterhin geprüft.
	-->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>src/*</exclude-pattern>
		<exclude-pattern>modules/*</exclude-pattern>
	</rule>

	<!--
	Action-/Filter-Pfade nutzen projektweit Slash-Notation (depeur_food/cache/purge, ADR-3).
	Dem ValidHookName-Sniff den Slash als erlaubten Worttrenner bekanntmachen.
	-->
	<rule ref="WordPress.NamingConventions.ValidHookName">
		<properties>
			<property name="additionalWordDelimiters" value="/"/>
		</properties>
	</rule>

	<!--
	PrefixAllGlobals mit den Projekt-Prefixen scharfschalten, damit globale Funktionen,
	Konstanten und (z. B. in uninstall.php) globale Variablen lokal geprüft werden — analog
	zur Strenge des WordPress-Plugin-Check. Namespaced Klassen (Depeur\Food\) gelten
	automatisch als geprefixt. Das Frontend-Kürzel df_ ist hier bewusst NICHT gelistet (vom
	Sniff als zu kurz abgelehnt); df_-Shortcodes werden ab Modul favorites separat behandelt.
	-->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="depeur_food"/>
				<element value="DEPEUR_FOOD"/>
			</property>
		</properties>
	</rule>

	<config name="minimum_supported_wp_version" value="6.5"/>
	<config name="testVersion" value="8.2-"/>
</ruleset>
